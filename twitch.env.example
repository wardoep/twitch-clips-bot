# Copy to twitch.env (chmod 600) and fill in.
# Discord bot: discord.com/developers/applications -> New Application -> Bot
#   Invite permissions: Manage Channels, Manage Roles, Manage Messages,
#   Pin Messages, Send Messages, Embed Links, Attach Files.
#   Enable the Message Content privileged intent for the paste channels.
CLIPS_DISCORD_TOKEN=
CLIPS_GUILD_ID=
CLIPS_CATEGORY_NAME=Twitch Clips
CLIPS_ADD_CHANNEL=➕🎬┃add-streamers
CLIPS_PING_CHANNEL=🔔┃live-pings
CLIPS_MSG_INTENT=1
# cadence
CLIPS_SWEEP_MINUTES=2
CLIPS_POLL_MINUTES=15
CLIPS_MAX_PER_REFRESH=30
CLIPS_RECAP_TIME=00:10
CLIPS_TZ=America/New_York
# Twitch app: dev.twitch.tv/console -> Register Your Application
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# OpenAI key powers transcripts (whisper-1), summaries, embeddings for /search
OPENAI_API_KEY=
